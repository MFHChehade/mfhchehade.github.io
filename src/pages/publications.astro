---
import Layout from '../layouts/Layout.astro';
import { peerReviewed, preprints, publications, topics } from '../data/research';

const featured = publications.filter((paper) => paper.image).slice(0, 6);
const topicName = (slug: string) => topics.find((topic) => topic.slug === slug)?.shortTitle ?? slug;
---

<Layout
  title="Publications - Mohamad Chehade"
  description="Peer-reviewed publications and preprints by Mohamad Chehade on risk-aware machine learning, reliable AI, reinforcement learning, LLMs, and power systems applications."
>
  <header class="page-heading publications-heading">
    <p class="eyebrow">Publications</p>
    <h1>Publications</h1>
    <p>
      Peer-reviewed publications and preprints in reliable machine learning, reinforcement learning,
      LLMs, optimization, and power systems applications.
    </p>
    <div class="publication-stats">
      <div>
        <span>{peerReviewed.length}</span>
        <strong>conference papers</strong>
      </div>
      <div>
        <span>{preprints.length}</span>
        <strong>preprint</strong>
      </div>
      <div>
        <span>{publications.length}</span>
        <strong>paper pages</strong>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Visual Index</p>
        <h2>Paper previews</h2>
      </div>
      <p>Selected papers with visuals cropped from their PDFs.</p>
    </div>

    <div class="featured-grid">
      {featured.map((paper) => (
        <article class="featured-paper">
          <a class="featured-image" href={`/publications/${paper.slug}`}>
            <img src={paper.image} alt={paper.imageAlt} />
          </a>
          <div class="featured-body">
            <div class="pub-topline">
              <span>{paper.year}</span>
              <span>{paper.shortVenue}</span>
            </div>
            <h3><a href={`/publications/${paper.slug}`}>{paper.shortTitle}</a></h3>
            <p>{paper.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Peer Reviewed</p>
        <h2>Conference publications</h2>
      </div>
      <p>{peerReviewed.length} papers</p>
    </div>
    <div class="publication-list rich-list">
      {peerReviewed.map((paper) => (
        <article class="publication-entry">
          <div class="pub-topline">
            <span>{paper.year}</span>
            <span>{paper.shortVenue}</span>
          </div>
          <h3><a href={`/publications/${paper.slug}`}>{paper.title}</a></h3>
          <p class="authors">{paper.authors}</p>
          <p class="venue">{paper.venue}</p>
          <div class="topic-row">
            {paper.topics.map((slug) => (
              <a href={`/research/${slug}`}>{topicName(slug)}</a>
            ))}
          </div>
          <div class="link-row">
            <a href={`/publications/${paper.slug}`}>details</a>
            {paper.links.map((link) => {
              const isExternal = link.href.startsWith("http");
              return (
                <a
                  href={link.href}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Preprints</p>
        <h2>Working papers</h2>
      </div>
    </div>
    <div class="publication-list rich-list">
      {preprints.map((paper) => (
        <article class="publication-entry">
          <div class="pub-topline">
            <span>{paper.year}</span>
            <span>{paper.shortVenue}</span>
          </div>
          <h3><a href={`/publications/${paper.slug}`}>{paper.title}</a></h3>
          <p class="authors">{paper.authors}</p>
          <p class="venue">{paper.venue}</p>
          <div class="topic-row">
            {paper.topics.map((slug) => (
              <a href={`/research/${slug}`}>{topicName(slug)}</a>
            ))}
          </div>
          <div class="link-row">
            <a href={`/publications/${paper.slug}`}>details</a>
            {paper.links.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .publications-heading {
    max-width: 940px;
  }

  .publication-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 1.35rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .publication-stats div {
    display: grid;
    gap: 0.1rem;
    padding: 0.9rem 1rem;
    border-right: 1px solid var(--line);
  }

  .publication-stats div:last-child {
    border-right: 0;
  }

  .publication-stats span {
    color: var(--burnt);
    font-size: 1.25rem;
    font-weight: 850;
  }

  .publication-stats strong {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .featured-paper {
    display: grid;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .featured-image {
    display: block;
    background: var(--soft);
  }

  .featured-image img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .featured-body {
    display: grid;
    gap: 0.55rem;
    padding: 0.95rem;
  }

  .featured-paper h3 {
    font-size: 1.06rem;
  }

  .featured-paper h3 a,
  .publication-entry h3 a {
    color: var(--charcoal);
    text-decoration: none;
  }

  .featured-paper h3 a:hover,
  .publication-entry h3 a:hover {
    color: var(--burnt);
  }

  .featured-paper p {
    color: var(--muted);
    margin: 0;
  }

  .topic-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.5rem;
  }

  .topic-row a {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    color: var(--green);
    background: #edf5ef;
    border: 1px solid rgba(36, 112, 95, 0.14);
    border-radius: 6px;
    padding: 0.12rem 0.5rem;
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: none;
  }

  .topic-row a:hover {
    color: #ffffff;
    background: var(--green);
  }

  @media (max-width: 900px) {
    .featured-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .publication-stats,
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .publication-stats div {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .publication-stats div:last-child {
      border-bottom: 0;
    }
  }
</style>
