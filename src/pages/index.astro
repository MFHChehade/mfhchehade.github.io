---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import NewsItem from '../components/NewsItem.astro';
import { topics, getTopicPapers } from '../data/research';

const researchThemes = topics.map((topic) => ({
  ...topic,
  count: getTopicPapers(topic.slug).length,
}));

const researchSignals = [
  { label: "Home", value: "UT Austin ECE" },
  { label: "Recent", value: "ICML 2025" },
  { label: "Methods", value: "RL / LLMs / Verification" },
  { label: "Applications", value: "Power systems" },
];

const selectedPublications = [
  {
    slug: "levis",
    authors: "M. Chehade, W. Li, B. W. Bell, R. Bent, S. R. Kazi, H. Zhu",
    title: "LEVIS: Large Exact Verifiable Input Spaces for Neural Networks",
    venue: "ICML 2025",
    year: "2025",
    shortVenue: "ICML",
    href: "https://doi.org/10.48550/arXiv.2408.08824",
  },
  {
    slug: "sitalign",
    authors: "M. Chehade, S. S. Ghosal, S. Chakraborty, A. Reddy, D. Manocha, H. Zhu, A. S. Bedi",
    title: "Bounded Rationality for LLMs: Satisficing Alignment at Inference-Time",
    venue: "ICML 2025",
    year: "2025",
    shortVenue: "ICML",
    href: "https://arxiv.org/abs/2505.23729",
  },
  {
    slug: "tram",
    authors: "M. Chehade, A. S. Bedi, A. Zhang, H. Zhu",
    title: "TRAM: Test-Time Risk Adaptation with Mixture of Agents",
    venue: "arXiv 2024",
    year: "2024",
    shortVenue: "arXiv",
    href: "https://doi.org/10.48550/arXiv.2408.08812",
  },
];
---

<Layout
  title="Mohamad Chehade - Ph.D. Student"
  description="Mohamad Chehade is a Ph.D. student at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">UT Austin ECE · Reliable learning systems</p>
      <h1>Mohamad <span class="name-accent">Chehade</span></h1>
      <p class="hero-statement">Reliable machine learning for risk, constraints, and decisions.</p>
      <div class="bio-block">
        <p>
          I am a Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin,
          advised by <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>.
          My research develops risk-aware and verifiable learning methods for decision-making under uncertainty,
          with applications in reinforcement learning, large language models, and power systems.
        </p>
        <p>
          I received my B.Eng. in Electrical and Computer Engineering, with a minor in Mathematics, from the
          <a href="https://www.aub.edu.lb/" target="_blank" rel="noopener noreferrer">American University of Beirut</a>,
          where I worked with
          <a href="https://scholar.google.com/citations?user=MUMy5mcAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Prof. Rabih Jabr</a>
          and
          <a href="https://scholar.google.com/citations?user=P8z1S1YAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Prof. Sami Karaki</a>.
          I have also interned at Los Alamos National Laboratory with Dr. Wenting Li, Dr. Brian Bell,
          and Dr. Russell Bent.
        </p>
      </div>
      <div class="button-row">
        <a class="button" href="/publications">Publications</a>
        <a class="button secondary" href="/research">Research</a>
        <a class="button secondary" href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">CV</a>
      </div>
      <div class="hero-social">
        <SocialLinks />
      </div>
    </div>

    <aside class="hero-media" aria-label="Research profile">
      <div class="portrait-shell">
        <img src="/profile.jpeg" alt="Mohamad Chehade" class="profile-photo" />
      </div>
      <div class="affiliation-strip">
        <span>Ph.D. Student</span>
        <strong>The University of Texas at Austin</strong>
        <a href="mailto:chehade@utexas.edu">chehade@utexas.edu</a>
      </div>
    </aside>

    <div class="signal-rail" aria-label="Research snapshot" data-reveal>
      {researchSignals.map((signal) => (
        <div>
          <span>{signal.label}</span>
          <strong>{signal.value}</strong>
        </div>
      ))}
    </div>
  </section>

  <section class="section flow-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Research</p>
        <h2>Research directions</h2>
      </div>
      <a href="/research">Explore all research</a>
    </div>

    <div class="theme-list">
      {researchThemes.map((theme) => (
        <a class="theme-row" href={`/research/${theme.slug}`} data-reveal>
          <span class="theme-index">{theme.index}</span>
          <div class="theme-body">
            <h3>{theme.shortTitle}</h3>
            <p>{theme.summary}</p>
          </div>
          <span class="theme-count">{theme.count} {theme.count === 1 ? "paper" : "papers"}</span>
          <span class="theme-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section quote-section" data-reveal>
    <figure class="cake-quote">
      <blockquote>
        If intelligence is a cake, the bulk of the cake is
        <span class="quote-mark q1">self-supervised learning</span>, the icing on the cake is
        <span class="quote-mark q2">supervised learning</span>, and the cherry on the cake is
        <span class="quote-mark q3">reinforcement learning</span>.
      </blockquote>
      <figcaption>
        <span class="cite-name">Yann LeCun</span>
        <span class="cite-role">on the role of learning paradigms in AI</span>
      </figcaption>
    </figure>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected Publications</p>
        <h2>Recent papers</h2>
      </div>
      <a href="/publications">View all publications</a>
    </div>

    <div class="publication-list">
      {selectedPublications.map((paper) => (
        <article class="publication-entry">
          <div class="pub-topline">
            <span>{paper.year}</span>
            <span>{paper.shortVenue}</span>
          </div>
          <h3><a href={`/publications/${paper.slug}`}>{paper.title}</a></h3>
          <p class="authors">{paper.authors}</p>
          <p class="venue">{paper.venue}</p>
          <div class="link-row">
            <a href={`/publications/${paper.slug}`}>details</a>
            <a href={paper.href} target="_blank" rel="noopener noreferrer">paper</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section lower-grid">
    <div>
      <div class="section-heading">
        <div>
          <p class="eyebrow">News</p>
          <h2>Recent updates</h2>
        </div>
      </div>

      <div class="news-list">
        <NewsItem
          date="Mar 2026"
          content='Two papers accepted to the <strong>2026 IEEE Power &amp; Energy Society General Meeting</strong>.'
        />
        <NewsItem
          date="Aug 2025"
          content='<a href="/Neo-Grid.pdf"><strong>NEO-Grid</strong></a> accepted to <strong>HICSS 2026</strong>.'
        />
        <NewsItem
          date="May 2025"
          content='Papers <strong>LEVIS</strong> and <strong>SITAlign</strong> accepted to <strong>ICML 2025</strong>.'
        />
        <NewsItem
          date="Oct 2024"
          content="Awarded Best Graduate Presentation Award at <strong>NAPS 2024</strong>."
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 350px);
    gap: 1.4rem 3rem;
    align-items: center;
    position: relative;
    padding: 3rem 0 1.6rem;
  }

  .hero-copy {
    max-width: 800px;
  }

  .name-accent {
    background: linear-gradient(120deg, var(--burnt-bright), var(--burnt-dark));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: var(--burnt);
  }

  .hero-statement {
    max-width: 720px;
    color: var(--charcoal);
    font-family: var(--serif);
    font-size: clamp(1.35rem, 2.6vw, 1.75rem);
    line-height: 1.32;
    font-weight: 500;
    margin: 1rem 0 1.2rem;
  }

  .bio-block {
    display: grid;
    gap: 0.7rem;
    max-width: 760px;
    margin-bottom: 1.25rem;
    color: var(--muted);
    font-size: 1.02rem;
  }

  .hero-social {
    margin-top: 1.1rem;
  }

  .hero-media {
    display: grid;
    gap: 0.75rem;
    align-self: stretch;
    justify-self: end;
    width: min(100%, 310px);
  }

  .portrait-shell {
    position: relative;
    padding: 0.55rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 18px;
    box-shadow: var(--shadow);
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 300ms ease;
  }

  .portrait-shell::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 18px;
    padding: 1px;
    background: linear-gradient(150deg, var(--accent-line), transparent 45%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .portrait-shell:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
  }

  .profile-photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 13px;
  }

  .affiliation-strip {
    display: grid;
    gap: 0.25rem;
    padding: 0.9rem 1rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-soft);
  }

  .affiliation-strip span {
    color: var(--burnt);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .affiliation-strip strong {
    color: var(--charcoal);
  }

  .signal-rail {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.45rem;
  }

  .signal-rail div {
    position: relative;
    min-height: 4.5rem;
    display: grid;
    align-content: center;
    gap: 0.25rem;
    padding: 0.9rem 1.05rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .signal-rail div::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(var(--burnt-bright), var(--burnt-dark));
  }

  .signal-rail div:hover {
    transform: translateY(-3px);
    border-color: var(--accent-line);
    box-shadow: var(--shadow);
  }

  .signal-rail span {
    color: var(--burnt);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .signal-rail strong {
    color: var(--ink);
    font-size: 1rem;
    font-weight: 600;
  }

  .theme-list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .theme-row {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0.4rem 1.5rem 0.2rem;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: padding 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-row::before {
    content: "";
    position: absolute;
    left: -1.4rem;
    right: -1.4rem;
    top: 0;
    bottom: -1px;
    background: var(--paper);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 220ms ease, transform 220ms ease;
    z-index: 0;
  }

  .theme-row:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .theme-row > * {
    position: relative;
    z-index: 1;
  }

  .theme-row:hover {
    padding-left: 1.6rem;
    padding-right: 1.4rem;
  }

  .theme-index {
    font-family: var(--serif);
    font-size: 2.1rem;
    font-weight: 500;
    line-height: 1;
    color: var(--line-strong);
    transition: color 220ms ease;
    font-variant-numeric: tabular-nums;
  }

  .theme-row:hover .theme-index {
    color: var(--burnt);
  }

  .theme-body h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    transition: color 200ms ease;
  }

  .theme-row:hover .theme-body h3 {
    color: var(--burnt);
  }

  .theme-body p {
    color: var(--muted);
    margin: 0;
    font-size: 0.97rem;
    max-width: 52ch;
  }

  .theme-count {
    color: var(--burnt);
    background: var(--accent-soft);
    border: 1px solid var(--accent-line);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--mono);
    white-space: nowrap;
  }

  .theme-arrow {
    display: inline-grid;
    place-items: center;
    color: var(--muted);
    transition: color 220ms ease, transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-row:hover .theme-arrow {
    color: var(--burnt);
    transform: translateX(5px);
  }

  @media (max-width: 720px) {
    .theme-row {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.9rem 1rem;
    }

    .theme-count {
      grid-column: 2 / 3;
      grid-row: 2;
      justify-self: start;
    }

    .theme-arrow {
      grid-column: 3;
      grid-row: 1 / 3;
    }

    .theme-index {
      font-size: 1.6rem;
    }

    .theme-body h3 {
      font-size: 1.12rem;
    }
  }

  .lower-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    align-items: start;
  }

  .quote-section {
    display: flex;
    justify-content: center;
  }

  .cake-quote {
    position: relative;
    max-width: 880px;
    margin: 0;
    padding: 2.6rem 2.4rem 2.4rem;
    background:
      radial-gradient(30rem 18rem at 100% 0%, var(--accent-soft), transparent 65%),
      var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .cake-quote::before {
    content: "\201C";
    position: absolute;
    top: -1.1rem;
    left: 1.2rem;
    font-family: var(--serif);
    font-size: 7rem;
    line-height: 1;
    color: var(--accent-line);
    pointer-events: none;
  }

  .cake-quote blockquote {
    position: relative;
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(1.35rem, 2.6vw, 1.85rem);
    font-weight: 500;
    line-height: 1.42;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .quote-mark {
    white-space: nowrap;
    font-weight: 600;
    background-image: linear-gradient(transparent 62%, var(--hl) 62%);
    padding: 0 0.05em;
  }

  .quote-mark.q1 { --hl: rgba(29, 111, 139, 0.22); color: var(--blue); }
  .quote-mark.q2 { --hl: rgba(42, 122, 95, 0.22); color: var(--green); }
  .quote-mark.q3 { --hl: var(--accent-soft); color: var(--burnt); }

  .cake-quote figcaption {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.2rem 0.7rem;
    margin-top: 1.5rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
  }

  .cite-name {
    font-weight: 700;
    color: var(--ink);
  }

  .cite-name::before {
    content: "\2014\00a0";
    color: var(--burnt);
  }

  .cite-role {
    color: var(--muted);
    font-size: 0.92rem;
  }

  @media (max-width: 820px) {
    .hero,
    .lower-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 1.6rem;
    }

    .hero-media {
      justify-self: center;
      width: min(100%, 340px);
    }

    .signal-rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .hero-statement {
      font-size: 1.18rem;
    }

    .signal-rail {
      grid-template-columns: 1fr;
    }

    .bio-block {
      font-size: 0.98rem;
    }

    .cake-quote {
      padding: 2rem 1.3rem 1.6rem;
    }

    .cake-quote::before {
      font-size: 5rem;
      top: -0.7rem;
      left: 0.7rem;
    }

    .quote-mark {
      white-space: normal;
    }
  }
</style>
