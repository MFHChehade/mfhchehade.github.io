---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import NewsItem from '../components/NewsItem.astro';

const researchInterests = [
  {
    title: "Risk-aware ML and RL",
    body: "Learning-based decision systems that account for uncertainty, distribution shift, and downside risk.",
  },
  {
    title: "Data-driven reliability",
    body: "Verification, stress testing, and reliability assessment for models deployed under constraints.",
  },
  {
    title: "LLMs for decisions",
    body: "Fine-tuning and inference-time methods for language models in structured technical domains.",
  },
];

const selectedPublications = [
  {
    authors: "M. Chehade, W. Li, B. W. Bell, R. Bent, S. R. Kazi, H. Zhu",
    title: "LEVIS: Large Exact Verifiable Input Spaces for Neural Networks",
    venue: "ICML 2025",
    href: "https://doi.org/10.48550/arXiv.2408.08824",
  },
  {
    authors: "M. Chehade, S. S. Ghosal, S. Chakraborty, A. Reddy, D. Manocha, H. Zhu, A. S. Bedi",
    title: "Bounded Rationality for LLMs: Satisficing Alignment at Inference-Time",
    venue: "ICML 2025",
    href: "https://arxiv.org/abs/2505.23729",
  },
  {
    authors: "M. Chehade, A. S. Bedi, A. Zhang, H. Zhu",
    title: "CAT: Caution Aware Transfer in Reinforcement Learning via Distributional Risk",
    venue: "arXiv 2024",
    href: "https://doi.org/10.48550/arXiv.2408.08812",
  },
];
---

<Layout
  title="Mohamad Chehade - Ph.D. Student"
  description="Mohamad Chehade is a Ph.D. student at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <section class="intro">
    <div class="intro-copy">
      <p class="eyebrow">Risk-aware machine learning and data-driven reliability</p>
      <h1>Mohamad Chehade</h1>
      <p class="lead">
        I am a Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin,
        advised by <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>.
        My research develops reliable learning methods for decision-making under uncertainty, with applications
        in reinforcement learning, large language models, and power systems.
      </p>
      <div class="button-row">
        <a class="button" href="/publications">Publications</a>
        <a class="button secondary" href="/research">Research</a>
        <a class="button secondary" href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">CV</a>
      </div>
    </div>

    <aside class="profile-panel surface">
      <img src="/profile.jpeg" alt="Mohamad Chehade" class="profile-photo" />
      <div>
        <h2>Mohamad Chehade</h2>
        <p>Ph.D. Student, UT Austin ECE</p>
      </div>
      <div class="profile-meta">
        <span>Risk-aware ML</span>
        <span>Reinforcement learning</span>
        <span>LLMs</span>
        <span>Power systems</span>
      </div>
      <p><a href="mailto:chehade@utexas.edu">chehade@utexas.edu</a></p>
      <SocialLinks />
    </aside>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Research</p>
        <h2>Research interests</h2>
      </div>
      <p>Methods for trustworthy learning in technical decision systems.</p>
    </div>

    <div class="modern-grid">
      {researchInterests.map((area) => (
        <article class="interest-card surface">
          <h3>{area.title}</h3>
          <p>{area.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected Publications</p>
        <h2>Recent papers</h2>
      </div>
      <a href="/publications">View all publications</a>
    </div>

    <div class="publication-list">
      {selectedPublications.map((paper) => (
        <article class="publication-entry">
          <h3>{paper.title}</h3>
          <p class="authors">{paper.authors}</p>
          <p class="venue">{paper.venue}</p>
          <div class="link-row">
            <a href={paper.href} target="_blank" rel="noopener noreferrer">paper</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">News</p>
        <h2>Recent updates</h2>
      </div>
    </div>

    <div class="news-list">
      <NewsItem
        date="Mar 2026"
        content='Two papers accepted to the <strong>2026 IEEE Power &amp; Energy Society General Meeting</strong>.'
      />
      <NewsItem
        date="Aug 2025"
        content='<a href="/Neo-Grid.pdf"><strong>NEO-Grid</strong></a> accepted to <strong>HICSS 2026</strong>.'
      />
      <NewsItem
        date="May 2025"
        content='Papers <strong>LEVIS</strong> and <strong>SITAlign</strong> accepted to <strong>ICML 2025</strong>.'
      />
      <NewsItem
        date="Oct 2024"
        content="Awarded Best Graduate Presentation Award at <strong>NAPS 2024</strong>."
      />
    </div>
  </section>

  <section class="section background-section">
    <div>
      <p class="eyebrow">Background</p>
      <h2>Education and collaborators</h2>
    </div>
    <p>
      I received my B.Eng. in Electrical and Computer Engineering, with a minor in Mathematics, from the
      <a href="https://www.aub.edu.lb/" target="_blank" rel="noopener noreferrer">American University of Beirut</a>,
      where I worked with
      <a href="https://scholar.google.com/citations?user=MUMy5mcAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Prof. Rabih Jabr</a>
      and
      <a href="https://scholar.google.com/citations?user=P8z1S1YAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Prof. Sami Karaki</a>.
      I have also interned at Los Alamos National Laboratory with Dr. Wenting Li, Dr. Brian Bell,
      and Dr. Russell Bent.
    </p>
  </section>
</Layout>

<style>
  .intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 2rem;
    align-items: start;
    padding: 1.25rem 0 1rem;
  }

  .intro-copy {
    max-width: 760px;
  }

  .intro .lead {
    margin: 1rem 0 1.4rem;
  }

  .profile-panel {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    border-top: 4px solid var(--burnt);
  }

  .profile-panel h2 {
    font-size: 1.2rem;
    margin: 0;
  }

  .profile-panel p {
    color: var(--muted);
    margin: 0;
  }

  .profile-photo {
    width: 100%;
    border-radius: 6px;
    border: 1px solid var(--line);
  }

  .profile-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .profile-meta span {
    color: var(--charcoal);
    background: var(--soft);
    border-radius: 6px;
    padding: 0.25rem 0.55rem;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .interest-card {
    padding: 1rem;
  }

  .interest-card h3 {
    margin-bottom: 0.5rem;
  }

  .interest-card p {
    color: var(--muted);
    margin: 0;
  }

  .background-section {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 1.5rem;
    padding: 1.25rem;
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .background-section p {
    margin: 0;
  }

  @media (max-width: 820px) {
    .intro,
    .background-section {
      grid-template-columns: 1fr;
    }
  }
</style>
