---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import NewsItem from '../components/NewsItem.astro';

const researchAreas = [
  {
    title: "Risk-aware machine learning and RL",
    body: "Methods for modeling uncertainty, distribution shift, and downside risk in learning-based decision systems.",
  },
  {
    title: "Data-driven reliability",
    body: "Verification, stress testing, and reliability assessment for models deployed under realistic operational constraints.",
  },
  {
    title: "LLMs for constrained decisions",
    body: "Fine-tuning and inference-time methods for using language models in structured technical decision-making problems.",
  },
];

const selectedPublications = [
  {
    title: "LEVIS: Large Exact Verifiable Input Spaces for Neural Networks",
    venue: "ICML 2025",
    href: "https://doi.org/10.48550/arXiv.2408.08824",
  },
  {
    title: "Bounded Rationality for LLMs: Satisficing Alignment at Inference-Time",
    venue: "ICML 2025",
    href: "https://arxiv.org/abs/2505.23729",
  },
  {
    title: "CAT: Caution Aware Transfer in Reinforcement Learning via Distributional Risk",
    venue: "arXiv 2024",
    href: "https://doi.org/10.48550/arXiv.2408.08812",
  },
  {
    title: "Fine-Tuning LLMs to Generate Economical and Reliable Actions for the Power Grid",
    venue: "IEEE PESGM 2026",
    href: "https://arxiv.org/abs/2602.15350",
  },
];
---

<Layout
  title="Mohamad Chehade - Ph.D. Student"
  description="Mohamad Chehade is a Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <header class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Machine learning, risk, and reliability</p>
      <h1>Mohamad Chehade</h1>
      <p class="hero-subtitle">Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin.</p>
      <p class="lead">
        My research develops risk-aware and data-driven methods for reliable machine learning,
        with an emphasis on reinforcement learning, large language models, and power systems applications.
      </p>
      <div class="button-row">
        <a class="button" href="/publications">View publications</a>
        <a class="button secondary" href="/research">Research areas</a>
        <a class="button secondary" href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">Download CV</a>
      </div>
      <SocialLinks />
    </div>

    <aside class="hero-profile" aria-label="Profile summary">
      <img src="/profile.jpeg" alt="Mohamad Chehade" class="profile-img" />
      <div class="profile-details">
        <span>Ph.D. Student, UT Austin ECE</span>
        <span>Advised by <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Dr. Hao Zhu</a></span>
        <span>Risk-aware ML, RL, LLMs, and reliability</span>
      </div>
    </aside>
  </header>

  <section class="section about-section" id="about">
    <div class="section-header">
      <div>
        <p class="eyebrow">About</p>
        <h2>Research interests and background</h2>
      </div>
    </div>

    <div class="about-grid">
      <div class="about-copy">
        <p>
          I am a Ph.D. student in <strong>Electrical and Computer Engineering</strong> at
          <a href="https://www.utexas.edu/" target="_blank" rel="noopener noreferrer">The University of Texas at Austin</a>,
          where I am advised by
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Dr. Hao Zhu</a>.
          My research focuses on risk-aware machine learning, data-driven reliability, and learning-based
          decision-making, with applications in reinforcement learning, large language models, and power systems.
        </p>
        <p>
          I earned my <strong>B.Eng. in Electrical and Computer Engineering</strong>, with a minor in Mathematics, from the
          <a href="https://www.aub.edu.lb/" target="_blank" rel="noopener noreferrer">American University of Beirut</a>.
          At AUB, I worked with
          <a href="https://scholar.google.com/citations?user=MUMy5mcAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Dr. Rabih Jabr</a>
          and
          <a href="https://scholar.google.com/citations?user=P8z1S1YAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Dr. Sami Karaki</a>.
          I have also interned at
          <a href="https://www.lanl.gov/" target="_blank" rel="noopener noreferrer">Los Alamos National Laboratory</a>,
          working with Dr. Wenting Li, Dr. Brian Bell, and Dr. Russell Bent.
        </p>
      </div>

      <div class="quick-facts">
        <div>
          <span class="fact-label">Affiliation</span>
          <strong>UT Austin ECE</strong>
        </div>
        <div>
          <span class="fact-label">Research</span>
          <strong>Risk-aware ML and data-driven reliability</strong>
        </div>
        <div>
          <span class="fact-label">Applications</span>
          <strong>RL, LLMs, and power systems</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="research-focus">
    <div class="section-header">
      <div>
        <p class="eyebrow">Research Focus</p>
        <h2>Research interests</h2>
      </div>
      <a href="/research">Read more</a>
    </div>

    <div class="card-grid">
      {researchAreas.map((area) => (
        <article class="info-card">
          <h3>{area.title}</h3>
          <p>{area.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="selected-publications">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Publications</p>
        <h2>Recent papers</h2>
      </div>
      <a href="/publications">Full list</a>
    </div>

    <div class="paper-list">
      {selectedPublications.map((paper) => (
        <article class="paper-item">
          <h3><a href={paper.href} target="_blank" rel="noopener noreferrer">{paper.title}</a></h3>
          <p>{paper.venue}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="news">
    <div class="section-header">
      <div>
        <p class="eyebrow">News</p>
        <h2>Recent updates</h2>
      </div>
    </div>

    <div class="news-list">
      <NewsItem
        date="Mar 2026"
        content='Two papers accepted to the <strong>2026 IEEE Power &amp; Energy Society General Meeting</strong>: <a href="https://arxiv.org/abs/2602.15350" target="_blank" rel="noopener noreferrer">Fine-Tuning LLMs to Generate Economical and Reliable Actions for the Power Grid</a> and <a href="https://arxiv.org/abs/2603.08654" target="_blank" rel="noopener noreferrer">Carbon-aware Market Participation for Building Energy Management Systems</a>.'
      />
      <NewsItem
        date="Aug 2025"
        content='<a href="/Neo-Grid.pdf"><strong>NEO-Grid</strong></a> accepted to <strong>HICSS 2026</strong>.'
      />
      <NewsItem
        date="May 2025"
        content='Papers <a href="https://arxiv.org/pdf/2408.08824" target="_blank" rel="noopener noreferrer"><strong>LEVIS</strong></a> and <a href="https://arxiv.org/pdf/2505.23729" target="_blank" rel="noopener noreferrer"><strong>SITAlign</strong></a> accepted to <strong>ICML 2025</strong>.'
      />
      <NewsItem
        date="Jan 2025"
        content='<a href="https://ieeexplore.ieee.org/document/10907217" target="_blank" rel="noopener noreferrer"><strong>BOOST</strong></a> accepted to <strong>TPEC 2025</strong>.'
      />
      <NewsItem
        date="Oct 2024"
        content="Awarded Best Graduate Presentation Award at <strong>NAPS 2024</strong>."
      />
    </div>
  </section>

  <section class="section" id="education">
    <div class="section-header">
      <div>
        <p class="eyebrow">Education</p>
        <h2>Academic path</h2>
      </div>
    </div>

    <div class="education-list">
      <article class="education-item">
        <div>
          <h3>Ph.D. in Electrical and Computer Engineering</h3>
          <p>The University of Texas at Austin</p>
          <p>
            Advisor:
            <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Dr. Hao Zhu</a>
          </p>
        </div>
        <span>Aug. 2023 - Present</span>
      </article>

      <article class="education-item">
        <div>
          <h3>B.Eng. in Electrical and Computer Engineering</h3>
          <p>American University of Beirut</p>
          <p>Minor in Mathematics</p>
        </div>
        <span>Aug. 2019 - Jun. 2023</span>
      </article>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
    min-height: calc(100vh - 190px);
    padding: 1rem 0 3rem;
    border-bottom: 1px solid var(--line);
  }

  .hero-copy {
    display: grid;
    gap: 1.2rem;
  }

  .hero-subtitle {
    color: var(--primary);
    font-size: 1.35rem;
    font-weight: 750;
  }

  .hero-profile {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .profile-img {
    width: min(100%, 340px);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 5px solid #ffffff;
    outline: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .profile-details {
    display: grid;
    gap: 0.6rem;
    padding-left: 1rem;
    border-left: 4px solid var(--primary);
    color: var(--muted);
    font-size: 0.98rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 2rem;
    align-items: start;
  }

  .about-copy {
    display: grid;
    gap: 1.1rem;
    font-size: 1.04rem;
  }

  .quick-facts {
    display: grid;
    gap: 0.8rem;
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-top: 4px solid var(--primary);
    border-radius: var(--radius);
    box-shadow: 0 10px 30px rgba(51, 63, 72, 0.06);
  }

  .quick-facts div {
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--line);
  }

  .quick-facts div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .fact-label {
    display: block;
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .news-list {
    background: var(--panel);
    border: 1px solid var(--line);
    border-top: 4px solid var(--primary);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .paper-list {
    display: grid;
    gap: 0.9rem;
  }

  .paper-item {
    padding: 1rem 0 1rem 1rem;
    border-left: 4px solid var(--primary);
    border-bottom: 1px solid var(--line);
  }

  .paper-item h3 {
    font-size: 1.08rem;
    line-height: 1.35;
  }

  .paper-item h3 a {
    color: var(--primary-dark);
    text-decoration: none;
  }

  .paper-item h3 a:hover {
    color: var(--primary);
    text-decoration: underline;
  }

  .paper-item p {
    color: var(--muted);
    margin-top: 0.25rem;
    font-style: italic;
  }

  .education-list {
    display: grid;
    gap: 1rem;
  }

  .education-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-left: 4px solid var(--primary);
    border-radius: var(--radius);
  }

  .education-item p {
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .education-item span {
    color: var(--primary);
    font-weight: 800;
    white-space: nowrap;
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-profile {
      align-items: flex-start;
    }

    .about-grid,
    .education-item {
      grid-template-columns: 1fr;
    }

    .education-item span {
      white-space: normal;
    }
  }
</style>
