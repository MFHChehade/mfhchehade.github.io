---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import NewsItem from '../components/NewsItem.astro';

const researchInterests = [
  "Risk-aware machine learning and reinforcement learning",
  "Data-driven reliability, verification, and stress testing",
  "Large language models for constrained technical decisions",
  "Power systems as a reliability-critical application domain",
];

const selectedPublications = [
  {
    authors: "M. Chehade, W. Li, B. W. Bell, R. Bent, S. R. Kazi, H. Zhu",
    title: "LEVIS: Large Exact Verifiable Input Spaces for Neural Networks",
    venue: "Proceedings of the 41st International Conference on Machine Learning (ICML), 2025",
    href: "https://doi.org/10.48550/arXiv.2408.08824",
  },
  {
    authors: "M. Chehade, S. S. Ghosal, S. Chakraborty, A. Reddy, D. Manocha, H. Zhu, A. S. Bedi",
    title: "Bounded Rationality for LLMs: Satisficing Alignment at Inference-Time",
    venue: "Proceedings of the 41st International Conference on Machine Learning (ICML), 2025",
    href: "https://arxiv.org/abs/2505.23729",
  },
  {
    authors: "M. Chehade, A. S. Bedi, A. Zhang, H. Zhu",
    title: "CAT: Caution Aware Transfer in Reinforcement Learning via Distributional Risk",
    venue: "arXiv, 2024",
    href: "https://doi.org/10.48550/arXiv.2408.08812",
  },
  {
    authors: "M. Chehade, H. Zhu",
    title: "Fine-Tuning LLMs to Generate Economical and Reliable Actions for the Power Grid",
    venue: "Accepted to 2026 IEEE Power & Energy Society General Meeting (PESGM), 2026",
    href: "https://arxiv.org/abs/2602.15350",
  },
];
---

<Layout
  title="Mohamad Chehade - Ph.D. Student"
  description="Mohamad Chehade is a Ph.D. student at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <div class="academic-grid">
    <article>
      <header class="page-heading">
        <h1>Biography</h1>
        <p>
          Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin.
        </p>
      </header>

      <section class="section">
        <p>
          I am a Ph.D. student in <strong>Electrical and Computer Engineering</strong> at
          <a href="https://www.utexas.edu/" target="_blank" rel="noopener noreferrer">The University of Texas at Austin</a>,
          advised by
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>.
          My research develops risk-aware and data-driven methods for reliable machine learning,
          with applications in reinforcement learning, large language models, and power systems.
        </p>
        <p>
          I received my B.Eng. in Electrical and Computer Engineering, with a minor in Mathematics, from the
          <a href="https://www.aub.edu.lb/" target="_blank" rel="noopener noreferrer">American University of Beirut</a>.
          At AUB, I worked with
          <a href="https://scholar.google.com/citations?user=MUMy5mcAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Prof. Rabih Jabr</a>
          and
          <a href="https://scholar.google.com/citations?user=P8z1S1YAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Prof. Sami Karaki</a>.
          I have also interned at Los Alamos National Laboratory with Dr. Wenting Li,
          Dr. Brian Bell, and Dr. Russell Bent.
        </p>
      </section>

      <section class="section">
        <h2>Research Interests</h2>
        <ul>
          {researchInterests.map((interest) => <li>{interest}</li>)}
        </ul>
      </section>

      <section class="section">
        <h2>Selected Publications</h2>
        <div class="publication-list">
          {selectedPublications.map((paper) => (
            <article class="publication-entry">
              <h3>{paper.title}</h3>
              <p class="authors">{paper.authors}</p>
              <p class="venue">{paper.venue}</p>
              <div class="link-row">
                <a href={paper.href} target="_blank" rel="noopener noreferrer">paper</a>
              </div>
            </article>
          ))}
        </div>
        <p class="more-link"><a href="/publications">Full publication list</a></p>
      </section>

      <section class="section">
        <h2>News</h2>
        <div class="news-list">
          <NewsItem
            date="Mar 2026"
            content='Two papers accepted to the <strong>2026 IEEE Power &amp; Energy Society General Meeting</strong>.'
          />
          <NewsItem
            date="Aug 2025"
            content='<a href="/Neo-Grid.pdf"><strong>NEO-Grid</strong></a> accepted to <strong>HICSS 2026</strong>.'
          />
          <NewsItem
            date="May 2025"
            content='Papers <strong>LEVIS</strong> and <strong>SITAlign</strong> accepted to <strong>ICML 2025</strong>.'
          />
          <NewsItem
            date="Jan 2025"
            content='<strong>BOOST</strong> accepted to <strong>TPEC 2025</strong>.'
          />
          <NewsItem
            date="Oct 2024"
            content="Awarded Best Graduate Presentation Award at <strong>NAPS 2024</strong>."
          />
        </div>
      </section>
    </article>

    <aside class="sidebar" aria-label="Profile details">
      <img src="/profile.jpeg" alt="Mohamad Chehade" class="profile-photo" />

      <section class="sidebar-section">
        <h2>Contact</h2>
        <p><a href="mailto:chehade@utexas.edu">chehade@utexas.edu</a></p>
        <SocialLinks />
      </section>

      <section class="sidebar-section">
        <h2>Affiliation</h2>
        <p>
          Department of Electrical and Computer Engineering<br />
          The University of Texas at Austin
        </p>
      </section>

      <section class="sidebar-section">
        <h2>Advisor</h2>
        <p>
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>
        </p>
      </section>

      <section class="sidebar-section">
        <h2>Education</h2>
        <p><strong>Ph.D.</strong>, UT Austin, 2023-present</p>
        <p><strong>B.Eng.</strong>, American University of Beirut, 2023</p>
      </section>

      <section class="sidebar-section">
        <h2>Documents</h2>
        <ul class="plain-list">
          <li><a href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">Curriculum vitae</a></li>
        </ul>
      </section>
    </aside>
  </div>
</Layout>

<style>
  .more-link {
    margin: 1rem 0 0;
  }
</style>
