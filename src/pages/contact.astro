---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<Layout
  title="Contact - Mohamad Chehade"
  description="Contact information for Mohamad Chehade, Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin."
>
  <header class="page-heading">
    <p class="eyebrow">Contact</p>
    <h1>Contact</h1>
    <p>
      Research conversations, collaboration questions, and related notes on reliable
      learning systems are welcome.
    </p>
  </header>

  <div class="contact-grid">
    <article class="contact-primary">
      <p class="eyebrow">Best way to reach me</p>
      <h2>Email</h2>
      <a class="email-callout" href="mailto:chehade@utexas.edu">chehade@utexas.edu</a>
      <p>
        I am especially interested in questions around risk-aware ML, data-driven
        reliability, RL, LLMs, and reliability-critical applications.
      </p>
    </article>

    <aside class="contact-panel">
      <section>
        <h2>Affiliation</h2>
        <p>
          Department of Electrical and Computer Engineering<br />
          The University of Texas at Austin
        </p>
      </section>

      <section>
        <h2>Advisor</h2>
        <p>
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>
        </p>
      </section>
      <section>
        <h2>Links</h2>
        <SocialLinks />
      </section>
      <section>
        <h2>Documents</h2>
        <ul class="plain-list">
          <li><a href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">Curriculum vitae</a></li>
        </ul>
      </section>
    </aside>
  </div>
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 390px);
    gap: 2rem;
    align-items: start;
  }

  .contact-primary {
    min-height: 22rem;
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: 1.4rem 0;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line);
  }

  .email-callout {
    display: inline-flex;
    width: fit-content;
    color: var(--burnt);
    font-size: 2rem;
    font-weight: 850;
    text-decoration: none;
  }

  .email-callout:hover {
    color: var(--burnt-dark);
  }

  .contact-panel {
    display: grid;
    gap: 1.2rem;
    padding: 1.1rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .contact-panel h2 {
    margin-bottom: 0.45rem;
  }

  .contact-panel p {
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .email-callout {
      font-size: 1.42rem;
    }
  }
</style>
