  description="Contact information for Mohamad Chehade, Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin."
>
  <header class="page-heading">
    <h1>Contact</h1>
    <p>
      Please feel free to contact me about research, collaboration, or related questions
      in risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs,
      and power systems applications.
    </p>
  </header>

  <div class="academic-grid">
    <article>
      <section class="section">
        <h2>Email</h2>
        <p><a href="mailto:chehade@utexas.edu">chehade@utexas.edu</a></p>
      </section>

      <section class="section">
        <h2>Affiliation</h2>
        <p>
          Department of Electrical and Computer Engineering<br />
          The University of Texas at Austin
        </p>
      </section>

      <section class="section">
        <h2>Advisor</h2>
        <p>
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>
        </p>
      </section>
    </article>

    <aside class="sidebar">
      <section class="sidebar-section">
        <h2>Links</h2>
        <SocialLinks />
