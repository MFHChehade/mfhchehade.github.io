---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<Layout
  title="Contact - Mohamad Chehade"
  description="Contact information for Mohamad Chehade, Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin."
>
  <header class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lead">
      I am happy to connect about risk-aware machine learning, data-driven reliability,
      reinforcement learning, LLMs, and power systems applications.
    </p>
  </header>

  <section class="section contact-grid">
    <article class="contact-card">
      <p class="eyebrow">Email</p>
      <h2>chehade@utexas.edu</h2>
      <p>
        The best way to reach me is by email. You can also find research updates and code
        through the links below.
      </p>
      <div class="button-row">
        <a class="button" href="mailto:chehade@utexas.edu">Email me</a>
        <a class="button secondary" href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">Download CV</a>
      </div>
      <SocialLinks />
    </article>

    <aside class="contact-details">
      <div>
        <span class="detail-label">Affiliation</span>
        <strong>The University of Texas at Austin</strong>
        <p>Electrical and Computer Engineering</p>
      </div>
      <div>
        <span class="detail-label">Advisor</span>
        <strong>
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Dr. Hao Zhu</a>
        </strong>
      </div>
      <div>
        <span class="detail-label">Research</span>
        <strong>Risk-aware ML, RL, LLMs, and PS applications</strong>
      </div>
    </aside>
  </section>
</Layout>

<style>
  .page-hero {
    max-width: 780px;
    padding: 2rem 0 1rem;
  }

  .page-hero h1 {
    margin-bottom: 1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 1.25rem;
    align-items: start;
  }

  .contact-card,
  .contact-details {
    padding: 1.5rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-top: 4px solid var(--primary);
    border-radius: var(--radius);
    box-shadow: 0 10px 30px rgba(51, 63, 72, 0.06);
  }

  .contact-card h2 {
    margin-bottom: 0.9rem;
    overflow-wrap: anywhere;
  }

  .contact-card p {
    color: var(--muted);
  }

  .contact-card .button-row,
  .contact-card :global(.social-links) {
    margin-top: 1.25rem;
  }

  .contact-details {
    display: grid;
    gap: 1rem;
  }

  .contact-details div {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }

  .contact-details div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .contact-details p {
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .detail-label {
    display: block;
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
