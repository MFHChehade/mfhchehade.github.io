---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<Layout
  title="Contact - Mohamad Chehade"
  description="Contact information for Mohamad Chehade, Ph.D. student in Electrical and Computer Engineering at The University of Texas at Austin."
>
  <header class="page-heading">
    <p class="eyebrow">Contact</p>
    <h1>Contact</h1>
    <p>
      Please feel free to contact me about research, collaboration, or related questions
      in risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs,
      and power systems applications.
    </p>
  </header>

  <div class="contact-grid">
    <article class="contact-panel surface">
      <section>
        <h2>Email</h2>
        <p><a href="mailto:chehade@utexas.edu">chehade@utexas.edu</a></p>
      </section>

      <section>
        <h2>Affiliation</h2>
        <p>
          Department of Electrical and Computer Engineering<br />
          The University of Texas at Austin
        </p>
      </section>

      <section>
        <h2>Advisor</h2>
        <p>
          <a href="https://sites.utexas.edu/haozhu/" target="_blank" rel="noopener noreferrer">Prof. Hao Zhu</a>
        </p>
      </section>
    </article>

    <aside class="contact-panel surface">
      <section>
        <h2>Links</h2>
        <SocialLinks />
      </section>
      <section>
        <h2>Documents</h2>
        <ul class="plain-list">
          <li><a href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">Curriculum vitae</a></li>
        </ul>
      </section>
    </aside>
  </div>
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 1rem;
  }

  .contact-panel {
    display: grid;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .contact-panel h2 {
    margin-bottom: 0.45rem;
  }

  .contact-panel p {
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
