---
import Layout from '../../layouts/Layout.astro';
import { getTopicPapers, topics } from '../../data/research';

export function getStaticPaths() {
  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const papers = getTopicPapers(topic.slug);
---

<Layout
  title={`${topic.title} - Mohamad Chehade`}
  description={`${topic.title}: ${topic.summary}`}
>
  <header class="topic-hero">
    <div class="topic-copy">
      <a class="back-link" href="/research">Research</a>
      <p class="eyebrow">{topic.index} / Research direction</p>
      <h1>{topic.title}</h1>
      <p class="lead">{topic.summary}</p>
      <p>{topic.focus}</p>
    </div>
    <figure class="topic-figure">
      <img src={topic.image} alt={topic.imageAlt} />
      <figcaption>Representative visual from a related paper.</figcaption>
    </figure>
  </header>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Papers</p>
        <h2>Related work in this direction</h2>
      </div>
      <p>{papers.length} papers connected to this topic.</p>
    </div>

    <div class="topic-paper-grid">
      {papers.map((paper) => (
        <article class="topic-paper">
          {paper.image ? (
            <a class="paper-thumb" href={`/publications/${paper.slug}`}>
              <img src={paper.image} alt={paper.imageAlt} />
            </a>
          ) : (
            <a class="paper-thumb fallback" href={`/publications/${paper.slug}`}>
              <span>{paper.shortVenue}</span>
              <strong>{paper.year}</strong>
            </a>
          )}
          <div>
            <div class="pub-topline">
              <span>{paper.year}</span>
              <span>{paper.shortVenue}</span>
            </div>
            <h3><a href={`/publications/${paper.slug}`}>{paper.title}</a></h3>
            <p>{paper.summary}</p>
            <div class="link-row">
              <a href={`/publications/${paper.slug}`}>details</a>
              {paper.links.map((link) => {
                const isExternal = link.href.startsWith("http");
                return (
                  <a
                    href={link.href}
                    target={isExternal ? "_blank" : undefined}
                    rel={isExternal ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                );
              })}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .topic-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
    gap: 2rem;
    align-items: center;
    padding: 3.2rem 0 1.4rem;
  }

  .topic-copy {
    max-width: 760px;
  }

  .topic-copy p {
    color: var(--muted);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--blue);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--burnt);
  }

  .topic-figure {
    margin: 0;
    padding: 0.75rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .topic-figure img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 6px;
  }

  .topic-figure figcaption {
    color: var(--muted);
    font-size: 0.88rem;
    margin-top: 0.55rem;
  }

  .topic-paper-grid {
    display: grid;
    gap: 1rem;
  }

  .topic-paper {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 1rem;
    padding: 0.85rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .paper-thumb {
    display: block;
    overflow: hidden;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 6px;
    text-decoration: none;
  }

  .paper-thumb img {
    width: 100%;
    height: 100%;
    min-height: 10.5rem;
    object-fit: cover;
  }

  .paper-thumb.fallback {
    min-height: 10.5rem;
    display: grid;
    place-content: center;
    gap: 0.2rem;
    color: var(--burnt);
  }

  .paper-thumb.fallback span,
  .paper-thumb.fallback strong {
    text-align: center;
  }

  .topic-paper h3 {
    margin-bottom: 0.45rem;
  }

  .topic-paper h3 a {
    color: var(--charcoal);
    text-decoration: none;
  }

  .topic-paper h3 a:hover {
    color: var(--burnt);
  }

  .topic-paper p {
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 820px) {
    .topic-hero,
    .topic-paper {
      grid-template-columns: 1fr;
    }

    .topic-hero {
      padding-top: 2rem;
    }
  }
</style>
