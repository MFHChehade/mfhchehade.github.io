---
import Layout from '../layouts/Layout.astro';

const areas = [
  {
    title: "Risk-aware transfer in reinforcement learning",
    body: "Developing methods that account for uncertainty and downside risk when policies move across environments or operating regimes.",
  },
  {
    title: "Physics-aware supervised learning",
    body: "Using structure from power systems, optimization, and control to make learned models more reliable and easier to verify.",
  },
  {
    title: "AI for grid operations",
    body: "Applying learning systems to practical energy decisions such as switching, battery control, market participation, and building energy management.",
  },
];
---

<Layout
  title="Research - Mohamad Chehade"
  description="Research areas for Mohamad Chehade, including risk-aware reinforcement learning, physics-aware learning, and AI for power systems."
>
  <header class="page-hero">
    <p class="eyebrow">Research</p>
    <h1>Reliable learning for energy decision-making.</h1>
    <p class="lead">
      My work studies machine learning methods that can operate under constraints, uncertainty,
      and changing grid conditions while remaining useful for real power system decisions.
    </p>
  </header>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Themes</p>
        <h2>Current directions</h2>
      </div>
    </div>

    <div class="card-grid">
      {areas.map((area) => (
        <article class="info-card">
          <h3>{area.title}</h3>
          <p>{area.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>Recent projects</h2>
      </div>
    </div>

    <div class="project-list">
      <article class="project">
        <div>
          <h3>NEO-Grid</h3>
          <p>
            A neural approximation framework for optimization and control in distribution grids,
            accepted to HICSS 2026.
          </p>
        </div>
        <a href="/Neo-Grid.pdf" target="_blank" rel="noopener noreferrer">Paper</a>
      </article>

      <article class="project">
        <div>
          <h3>LEVIS</h3>
          <p>
            Exact and verifiable input-space construction for neural networks, accepted to ICML 2025.
          </p>
        </div>
        <a href="https://doi.org/10.48550/arXiv.2408.08824" target="_blank" rel="noopener noreferrer">Paper</a>
      </article>

      <article class="project">
        <div>
          <h3>Grid-oriented LLM fine-tuning</h3>
          <p>
            Fine-tuning large language models to generate economical and reliable corrective
            actions for power grid scenarios.
          </p>
        </div>
        <a href="https://arxiv.org/abs/2602.15350" target="_blank" rel="noopener noreferrer">arXiv</a>
      </article>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    max-width: 820px;
    padding: 2rem 0 1rem;
  }

  .page-hero h1 {
    margin-bottom: 1rem;
  }

  .project-list {
    display: grid;
    gap: 1rem;
  }

  .project {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-left: 4px solid var(--primary);
    border-radius: var(--radius);
  }

  .project p {
    color: var(--muted);
    margin-top: 0.45rem;
  }

  .project a {
    min-height: 2.3rem;
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    color: var(--primary);
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 6px;
    font-weight: 750;
    text-decoration: none;
  }

  .project a:hover {
    color: #ffffff;
    background: var(--primary);
    text-decoration: none;
  }

  @media (max-width: 680px) {
    .project {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
