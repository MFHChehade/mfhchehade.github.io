---
import Layout from '../layouts/Layout.astro';
import { getTopicPapers, topics } from '../data/research';
---

<Layout
  title="Research - Mohamad Chehade"
  description="Research areas for Mohamad Chehade, including risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <header class="page-heading research-heading">
    <p class="eyebrow">Research</p>
    <h1>Research</h1>
    <p>
      My work studies reliable learning systems for decisions under uncertainty. The pages below organize
      projects by research direction and connect each topic to the papers that develop it.
    </p>
  </header>

  <section class="section topic-overview">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Themes</p>
        <h2>Research directions</h2>
      </div>
      <p>Each direction includes multiple related papers and paper-derived visuals.</p>
    </div>

    <div class="topic-grid">
      {topics.map((topic) => {
        const topicPapers = getTopicPapers(topic.slug);
        return (
          <article class="topic-card">
            <a class="topic-image" href={`/research/${topic.slug}`} aria-label={`Open ${topic.title}`}>
              <img src={topic.image} alt={topic.imageAlt} />
            </a>
            <div class="topic-body">
              <div class="topic-topline">
                <span>{topic.index}</span>
                <span>{topicPapers.length} papers</span>
              </div>
              <h3><a href={`/research/${topic.slug}`}>{topic.title}</a></h3>
              <p>{topic.summary}</p>
              <div class="mini-paper-list">
                {topicPapers.slice(0, 3).map((paper) => (
                  <a href={`/publications/${paper.slug}`}>{paper.shortTitle}</a>
                ))}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .research-heading {
    max-width: 920px;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .topic-card {
    display: grid;
    grid-template-columns: minmax(190px, 0.82fr) minmax(0, 1fr);
    gap: 1rem;
    min-height: 17rem;
    padding: 0.85rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .topic-image {
    display: block;
    min-height: 100%;
    overflow: hidden;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 6px;
  }

  .topic-image img {
    width: 100%;
    height: 100%;
    min-height: 15rem;
    object-fit: cover;
  }

  .topic-body {
    display: grid;
    align-content: start;
    gap: 0.7rem;
    padding: 0.15rem 0.2rem 0.15rem 0;
  }

  .topic-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .topic-topline span {
    display: inline-flex;
    align-items: center;
    min-height: 1.55rem;
    color: var(--burnt);
    background: var(--warm);
    border: 1px solid rgba(191, 87, 0, 0.16);
    border-radius: 6px;
    padding: 0.1rem 0.45rem;
    font-size: 0.78rem;
    font-weight: 850;
  }

  .topic-card h3 {
    font-size: 1.15rem;
  }

  .topic-card h3 a {
    color: var(--charcoal);
    text-decoration: none;
  }

  .topic-card h3 a:hover {
    color: var(--burnt);
  }

  .topic-card p {
    color: var(--muted);
    margin: 0;
  }

  .mini-paper-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.3rem;
  }

  .mini-paper-list a {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    color: var(--blue);
    background: var(--wash);
    border: 1px solid rgba(10, 103, 133, 0.12);
    border-radius: 6px;
    padding: 0.18rem 0.55rem;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .mini-paper-list a:hover {
    color: #ffffff;
    background: var(--burnt);
  }

  @media (max-width: 960px) {
    .topic-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .topic-card {
      grid-template-columns: 1fr;
    }

    .topic-image img {
      min-height: 12rem;
    }
  }
</style>
