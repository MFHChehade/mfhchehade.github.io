---
import Layout from '../layouts/Layout.astro';

const areas = [
  {
    title: "Risk-aware machine learning and reinforcement learning",
    body: "I study methods that account for uncertainty, distribution shift, and downside risk in learning-based decision systems, particularly when policies are transferred across environments or operating regimes.",
  },
  {
    title: "Data-driven reliability and verification",
    body: "I am interested in reliability assessment, stress testing, and verifiable input-space construction for learned models deployed under realistic constraints.",
  },
  {
    title: "LLMs for constrained decision-making",
    body: "I study how large language models can support reliable actions in structured technical domains, including settings where decisions must satisfy operational or physical constraints.",
  },
  {
    title: "Power systems applications",
    body: "Power systems provide a reliability-critical application domain for studying data-driven control, optimization, market participation, and learning-based decision support.",
  },
];

const projects = [
  {
    title: "CAT",
    body: "Caution-aware transfer in reinforcement learning via distributional risk, focused on robust policy transfer under uncertainty.",
    href: "https://doi.org/10.48550/arXiv.2408.08812",
    label: "arXiv",
  },
  {
    title: "SITAlign",
    body: "Bounded rationality for LLMs through satisficing alignment at inference time, accepted to ICML 2025.",
    href: "https://arxiv.org/abs/2505.23729",
    label: "paper",
  },
  {
    title: "LEVIS",
    body: "Exact and verifiable input-space construction for neural networks, accepted to ICML 2025.",
    href: "https://doi.org/10.48550/arXiv.2408.08824",
    label: "paper",
  },
  {
    title: "LLM fine-tuning for constrained actions",
    body: "Fine-tuning large language models to generate economical and reliable corrective actions, with power systems as a testbed.",
    href: "https://arxiv.org/abs/2602.15350",
    label: "arXiv",
  },
];
---

<Layout
  title="Research - Mohamad Chehade"
  description="Research areas for Mohamad Chehade, including risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <header class="page-heading">
    <h1>Research</h1>
    <p>
      My work develops learning methods that remain useful under uncertainty, constraints,
      and distribution shift, with emphasis on reinforcement learning, LLMs, verification,
      and reliability-critical applications.
    </p>
  </header>

  <section class="section">
    <h2>Research Interests</h2>
    <div class="research-list">
      {areas.map((area) => (
        <article class="research-entry">
          <h3>{area.title}</h3>
          <p>{area.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Selected Projects</h2>
    <div class="publication-list">
      {projects.map((project) => (
        <article class="publication-entry">
          <h3>{project.title}</h3>
          <p>{project.body}</p>
          <div class="link-row">
            <a href={project.href} target="_blank" rel="noopener noreferrer">{project.label}</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .research-list {
    display: grid;
    gap: 1rem;
  }

  .research-entry {
    padding: 0.85rem 0.9rem;
    border: 1px solid transparent;
    border-bottom: 1px solid var(--line);
    border-radius: var(--radius);
    transition:
      background 160ms ease,
      border-color 160ms ease;
  }

  .research-entry:last-child {
    border-bottom-color: transparent;
  }

  .research-entry:hover {
    background: #ffffff;
    border-color: var(--line);
  }

  .research-entry h3 {
    margin-bottom: 0.25rem;
  }
</style>
