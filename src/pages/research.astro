---
import Layout from '../layouts/Layout.astro';

const areas = [
  {
    title: "Risk-aware machine learning and RL",
    body: "Developing methods that account for uncertainty, distribution shift, and downside risk when policies move across environments or operating regimes.",
  },
  {
    title: "Data-driven reliability and verification",
    body: "Building learned models whose predictions and decisions can be stress-tested, verified, and trusted under realistic constraints.",
  },
  {
    title: "LLMs for constrained decision-making",
    body: "Studying how large language models can support reliable actions in technical domains, including power systems, control, and optimization.",
  },
];
---

<Layout
  title="Research - Mohamad Chehade"
  description="Research areas for Mohamad Chehade, including risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications."
>
  <header class="page-hero">
    <p class="eyebrow">Research</p>
    <h1>Risk-aware machine learning for reliable decisions.</h1>
    <p class="lead">
      My work studies learning methods that remain useful under uncertainty, constraints,
      and distribution shift, with applications in RL, LLMs, and power systems.
    </p>
  </header>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Themes</p>
        <h2>Current directions</h2>
      </div>
    </div>

    <div class="card-grid">
      {areas.map((area) => (
        <article class="info-card">
          <h3>{area.title}</h3>
          <p>{area.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>Recent projects</h2>
      </div>
    </div>

    <div class="project-list">
      <article class="project">
        <div>
          <h3>CAT</h3>
          <p>
            Caution-aware transfer in reinforcement learning via distributional risk, focused on
            robust policy transfer under uncertainty.
          </p>
        </div>
        <a href="https://doi.org/10.48550/arXiv.2408.08812" target="_blank" rel="noopener noreferrer">arXiv</a>
      </article>

      <article class="project">
        <div>
          <h3>SITAlign</h3>
          <p>
            Bounded rationality for LLMs through satisficing alignment at inference time,
            accepted to ICML 2025.
          </p>
        </div>
        <a href="https://arxiv.org/abs/2505.23729" target="_blank" rel="noopener noreferrer">Paper</a>
      </article>

      <article class="project">
        <div>
          <h3>LEVIS</h3>
          <p>
            Exact and verifiable input-space construction for neural networks, accepted to ICML 2025.
          </p>
        </div>
        <a href="https://doi.org/10.48550/arXiv.2408.08824" target="_blank" rel="noopener noreferrer">Paper</a>
      </article>

      <article class="project">
        <div>
          <h3>LLM fine-tuning for constrained actions</h3>
          <p>
            Fine-tuning large language models to generate economical and reliable corrective actions,
            with power systems as a testbed.
          </p>
        </div>
        <a href="https://arxiv.org/abs/2602.15350" target="_blank" rel="noopener noreferrer">arXiv</a>
      </article>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    max-width: 820px;
    padding: 2rem 0 1rem;
  }

  .page-hero h1 {
    margin-bottom: 1rem;
  }

  .project-list {
    display: grid;
    gap: 1rem;
  }

  .project {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-left: 4px solid var(--primary);
    border-radius: var(--radius);
  }

  .project p {
    color: var(--muted);
    margin-top: 0.45rem;
  }

  .project a {
    min-height: 2.3rem;
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    color: var(--primary);
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 6px;
    font-weight: 750;
    text-decoration: none;
  }

  .project a:hover {
    color: #ffffff;
    background: var(--primary);
    text-decoration: none;
  }

  @media (max-width: 680px) {
    .project {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
