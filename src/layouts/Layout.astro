---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Mohamad Chehade is a Ph.D. student at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications.",
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/profile.jpeg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <div class="site-header-inner">
        <div class="site-identity">
          <a href="/" class="site-name">Mohamad Chehade</a>
          <p>Ph.D. Student, Electrical and Computer Engineering, The University of Texas at Austin</p>
        </div>
        <nav class="site-nav" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[{ active: isActive(link.href) }]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
          <a href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">CV</a>
        </nav>
      </div>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Mohamad Chehade</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ut-burnt: #bf5700;
    --ut-charcoal: #333f48;
    --link: #005f86;
    --ink: #222222;
    --muted: #5f6870;
    --line: #d9dde0;
    --soft: #f4f6f7;
    --panel: #ffffff;
    --background: #f8f9f9;
    --max-width: 1120px;
    --radius: 8px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--ink);
    background: var(--background);
    font-family: Arial, Helvetica, sans-serif;
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    margin: 0;
    line-height: 1.58;
    display: flex;
    flex-direction: column;
    background:
      linear-gradient(180deg, #ffffff 0, var(--background) 360px),
      var(--background);
    border-top: 4px solid var(--ut-burnt);
  }

  img {
    max-width: 100%;
    display: block;
  }

  main {
    width: min(100% - 2rem, var(--max-width));
    flex: 1;
    margin: 0 auto;
    padding: 2.5rem 0 3.5rem;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.45rem 0.65rem;
    color: #ffffff;
    background: var(--ut-charcoal);
    border-radius: 4px;
    transform: translateY(-150%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(255, 255, 255, 0.92);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(14px);
  }

  .site-header-inner {
    width: min(100% - 2rem, var(--max-width));
    margin: 0 auto;
    padding: 1rem 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-identity {
    min-width: 0;
  }

  .site-name {
    color: var(--ut-charcoal);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.72rem;
    line-height: 1.1;
    font-weight: 700;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .site-name:hover {
    color: var(--ut-burnt);
    text-decoration: none;
  }

  .site-identity p {
    color: var(--muted);
    margin: 0.35rem 0 0;
    font-size: 0.92rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.45rem;
    font-size: 0.95rem;
  }

  .site-nav a {
    color: var(--ut-charcoal);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.28rem 0.55rem;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--ut-burnt);
    background: #fff7f0;
    border-color: #efc7a5;
  }

  footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
    padding: 1.2rem 1rem;
    background: #ffffff;
  }

  footer p {
    width: min(100%, var(--max-width));
    margin: 0 auto;
  }

  h1,
  h2,
  h3 {
    color: var(--ut-charcoal);
    margin: 0;
    line-height: 1.25;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.15rem;
    font-weight: 700;
    margin-bottom: 0.45rem;
  }

  h2 {
    font-size: 1.22rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--line);
  }

  h3 {
    font-size: 1rem;
  }

  p {
    margin: 0 0 0.85rem;
  }

  a {
    color: var(--link);
    text-underline-offset: 0.16em;
    transition: color 160ms ease;
  }

  a:hover {
    color: var(--ut-burnt);
  }

  ul,
  ol {
    margin: 0.25rem 0 0.75rem 1.2rem;
    padding: 0;
  }

  li {
    margin: 0.25rem 0;
  }

  :focus-visible {
    outline: 2px solid var(--ut-burnt);
    outline-offset: 3px;
  }

  .page-heading {
    margin-bottom: 1.8rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }

  .page-heading p {
    max-width: 760px;
    color: var(--muted);
    margin-bottom: 0;
  }

  .section {
    margin-top: 2.35rem;
  }

  .section:first-child {
    margin-top: 0;
  }

  .academic-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(230px, 270px);
    gap: 3rem;
    align-items: start;
  }

  .sidebar {
    position: sticky;
    top: 6rem;
    font-size: 0.94rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-top: 3px solid var(--ut-burnt);
    border-radius: var(--radius);
    padding: 1rem;
  }

  .sidebar-section {
    padding: 0.95rem 0;
    border-top: 1px solid var(--line);
  }

  .sidebar-section:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .sidebar-section h2,
  .sidebar-section h3 {
    font-size: 0.95rem;
    margin-bottom: 0.4rem;
    padding: 0;
    border: 0;
  }

  .profile-photo {
    width: 100%;
    max-width: 215px;
    margin: 0 auto 1rem;
    border: 1px solid var(--line);
    border-radius: 4px;
  }

  .plain-list {
    list-style: none;
    margin-left: 0;
  }

  .plain-list li {
    margin: 0.35rem 0;
  }

  .publication-list,
  .news-list {
    display: grid;
    gap: 0.55rem;
  }

  .publication-entry {
    padding: 0.85rem 0.9rem;
    border: 1px solid transparent;
    border-bottom-color: var(--line);
    border-radius: var(--radius);
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .publication-entry:last-child {
    border-bottom-color: transparent;
  }

  .publication-entry:hover {
    background: var(--panel);
    border-color: var(--line);
    transform: translateY(-1px);
  }

  .publication-entry h3 {
    color: var(--ink);
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .publication-entry p {
    margin-bottom: 0.25rem;
  }

  .authors {
    color: var(--ink);
  }

  .venue,
  .meta {
    color: var(--muted);
    font-style: italic;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.92rem;
  }

  .link-row a {
    text-decoration: none;
  }

  .link-row a::before {
    content: "[";
    color: var(--muted);
  }

  .link-row a::after {
    content: "]";
    color: var(--muted);
  }

  .academic-note {
    background: var(--soft);
    border-left: 3px solid var(--ut-burnt);
    padding: 0.8rem 1rem;
    border-radius: 0 6px 6px 0;
  }

  @media (max-width: 760px) {
    main,
    .site-header-inner {
      width: min(100% - 1.2rem, var(--max-width));
    }

    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.75rem;
    }

    .site-header {
      position: static;
    }

    .site-nav {
      justify-content: flex-start;
      gap: 0.7rem;
    }

    h1 {
      font-size: 1.8rem;
    }

    .academic-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      position: static;
    }

    .profile-photo {
      width: 170px;
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
