---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Mohamad Chehade is a Ph.D. student at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications.",
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/profile.jpeg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-name" aria-label="Mohamad Chehade home">
          <span class="site-mark">MC</span>
          <span>Mohamad Chehade</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[{ active: isActive(link.href) }]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
          <a href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">CV</a>
        </nav>
      </div>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p>&copy; {new Date().getFullYear()} Mohamad Chehade</p>
        <p>Risk-aware ML, data-driven reliability, RL, LLMs, and power systems applications.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --burnt: #bf5700;
    --charcoal: #27313b;
    --ink: #17202a;
    --muted: #637083;
    --blue: #005f86;
    --green: #22715f;
    --bg: #f6f7f4;
    --paper: #ffffff;
    --wash: #eef4f5;
    --warm: #fff6ef;
    --line: #d9dee3;
    --shadow: 0 18px 45px rgba(39, 49, 59, 0.08);
    --radius: 8px;
    --max-width: 1120px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    margin: 0;
    line-height: 1.62;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border-top: 4px solid var(--burnt);
  }

  img {
    max-width: 100%;
    display: block;
  }

  main {
    width: min(100% - 2rem, var(--max-width));
    flex: 1;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.45rem 0.65rem;
    color: #ffffff;
    background: var(--charcoal);
    border-radius: 4px;
    transform: translateY(-150%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(246, 247, 244, 0.88);
    border-bottom: 1px solid rgba(217, 222, 227, 0.86);
    backdrop-filter: blur(18px);
  }

  .site-header-inner {
    width: min(100% - 2rem, var(--max-width));
    min-height: 72px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-name {
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-mark {
    width: 2.2rem;
    height: 2.2rem;
    display: inline-grid;
    place-items: center;
    color: #ffffff;
    background: var(--charcoal);
    border-radius: 6px;
    font-size: 0.76rem;
    font-weight: 800;
  }

  .site-name:hover {
    color: var(--burnt);
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
    font-size: 0.95rem;
  }

  .site-nav a {
    min-height: 2.25rem;
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 0.32rem 0.7rem;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--burnt);
    background: #ffffff;
    border-color: var(--line);
  }

  footer {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 1.4rem 1rem;
    background: #ffffff;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    width: min(100%, var(--max-width));
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  h1,
  h2,
  h3 {
    color: var(--charcoal);
    margin: 0;
    line-height: 1.16;
  }

  h1 {
    font-size: 3.35rem;
    font-weight: 850;
  }

  h2 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
  }

  h3 {
    font-size: 1.05rem;
  }

  p {
    margin: 0 0 0.85rem;
  }

  a {
    color: var(--blue);
    text-underline-offset: 0.18em;
    transition: color 160ms ease;
  }

  a:hover {
    color: var(--burnt);
  }

  ul,
  ol {
    margin: 0.35rem 0 0.75rem 1.2rem;
    padding: 0;
  }

  li {
    margin: 0.3rem 0;
  }

  .plain-list {
    list-style: none;
    margin-left: 0;
  }

  :focus-visible {
    outline: 2px solid var(--burnt);
    outline-offset: 3px;
  }

  .page-heading {
    max-width: 820px;
    margin-bottom: 2rem;
  }

  .page-heading p,
  .lead {
    color: var(--muted);
    font-size: 1.08rem;
  }

  .eyebrow {
    color: var(--burnt);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.55rem;
  }

  .section {
    margin-top: 3rem;
  }

  .section:first-child {
    margin-top: 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-heading p {
    color: var(--muted);
    margin: 0;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    background: var(--charcoal);
    border: 1px solid var(--charcoal);
    border-radius: 6px;
    padding: 0.62rem 0.95rem;
    font-weight: 750;
    text-decoration: none;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    color: #ffffff;
    background: var(--burnt);
    border-color: var(--burnt);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .button.secondary {
    color: var(--charcoal);
    background: #ffffff;
    border-color: var(--line);
  }

  .button.secondary:hover {
    color: var(--burnt);
    background: var(--warm);
    border-color: #efc7a5;
  }

  .modern-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .surface {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .publication-list,
  .news-list {
    display: grid;
    gap: 0.75rem;
  }

  .publication-entry {
    padding: 1rem;
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .publication-entry:hover {
    border-color: #c8d3d8;
    box-shadow: 0 12px 30px rgba(39, 49, 59, 0.07);
    transform: translateY(-1px);
  }

  .publication-entry h3 {
    color: var(--ink);
    margin-bottom: 0.35rem;
  }

  .publication-entry p {
    margin-bottom: 0.28rem;
  }

  .authors {
    color: var(--ink);
  }

  .venue,
  .meta {
    color: var(--muted);
    font-style: italic;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.92rem;
    margin-top: 0.45rem;
  }

  .link-row a {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    color: var(--blue);
    background: var(--wash);
    border-radius: 6px;
    padding: 0.18rem 0.55rem;
    text-decoration: none;
  }

  .link-row a:hover {
    color: #ffffff;
    background: var(--burnt);
  }

  @media (max-width: 820px) {
    main,
    .site-header-inner {
      width: min(100% - 1.2rem, var(--max-width));
    }

    .site-header {
      position: static;
    }

    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.85rem;
      padding: 0.9rem 0;
    }

    .site-nav {
      justify-content: flex-start;
    }

    h1 {
      font-size: 2.3rem;
    }

    h2 {
      font-size: 1.35rem;
    }

    .modern-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
