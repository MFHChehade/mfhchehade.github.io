---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Mohamad Chehade is a Ph.D. student at The University of Texas at Austin working on risk-aware machine learning, data-driven reliability, reinforcement learning, LLMs, and power systems applications.",
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/profile.jpeg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="bg-aura" aria-hidden="true"></div>

    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-name" aria-label="Mohamad Chehade home">
          <span class="site-mark">MC</span>
          <span class="site-name-text">Mohamad Chehade</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[{ active: isActive(link.href) }]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
          <a class="nav-cv" href="/CV_Mohamad.pdf" target="_blank" rel="noopener noreferrer">CV</a>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
            <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
            </svg>
            <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="site-mark small">MC</span>
          <div>
            <strong>Mohamad Chehade</strong>
            <p>Reliable learning systems for risk-aware decisions.</p>
          </div>
        </div>
        <div class="footer-links">
          <a href="https://scholar.google.com/citations?user=cVUnhukAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Scholar</a>
          <a href="https://github.com/MFHChehade" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://lb.linkedin.com/in/mfhchehade" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:chehade@utexas.edu">Email</a>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Mohamad Chehade</p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const btn = document.getElementById("theme-toggle");
        if (btn) {
          btn.addEventListener("click", function () {
            const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
            document.documentElement.dataset.theme = next;
            try { localStorage.setItem("theme", next); } catch (e) {}
          });
        }
        // Scroll reveal
        const els = document.querySelectorAll("[data-reveal]");
        if ("IntersectionObserver" in window && els.length) {
          const io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          }, { threshold: 0.12, rootMargin: "0px 0px -40px 0px" });
          els.forEach(function (el) { io.observe(el); });
        } else {
          els.forEach(function (el) { el.classList.add("is-visible"); });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --burnt: #c25e10;
    --burnt-bright: #e2701a;
    --burnt-dark: #9a4709;
    --accent-soft: rgba(194, 94, 16, 0.1);
    --accent-line: rgba(194, 94, 16, 0.22);

    --ink: #1b1f24;
    --charcoal: #2b333d;
    --muted: #5c6773;
    --bg: #faf8f4;
    --bg-2: #f3efe7;
    --paper: #ffffff;
    --paper-2: #fcfaf6;
    --line: #e6e1d7;
    --line-strong: #d3ccbe;

    --blue: #1d6f8b;
    --green: #2a7a5f;

    --shadow-soft: 0 2px 4px rgba(27, 31, 36, 0.04), 0 8px 24px rgba(27, 31, 36, 0.06);
    --shadow: 0 4px 8px rgba(27, 31, 36, 0.05), 0 24px 60px rgba(27, 31, 36, 0.1);
    --shadow-lift: 0 8px 16px rgba(27, 31, 36, 0.08), 0 30px 70px rgba(194, 94, 16, 0.12);

    --radius: 14px;
    --radius-sm: 10px;
    --max-width: 1140px;

    --serif: "Source Serif 4", Georgia, Cambria, "Times New Roman", ui-serif, serif;
    --sans: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
    --mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
  }

  :root[data-theme="dark"] {
    --burnt: #f08a3c;
    --burnt-bright: #ff9d52;
    --burnt-dark: #d8722a;
    --accent-soft: rgba(240, 138, 60, 0.12);
    --accent-line: rgba(240, 138, 60, 0.28);

    --ink: #ece7df;
    --charcoal: #d8d2c8;
    --muted: #9aa3ad;
    --bg: #14171c;
    --bg-2: #1a1e24;
    --paper: #1c2027;
    --paper-2: #21262e;
    --line: #2e343d;
    --line-strong: #3c434d;

    --blue: #5bb6d4;
    --green: #5fc09c;

    --shadow-soft: 0 2px 4px rgba(0, 0, 0, 0.3), 0 8px 24px rgba(0, 0, 0, 0.35);
    --shadow: 0 4px 8px rgba(0, 0, 0, 0.35), 0 24px 60px rgba(0, 0, 0, 0.5);
    --shadow-lift: 0 8px 16px rgba(0, 0, 0, 0.4), 0 30px 70px rgba(240, 138, 60, 0.1);
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--ink);
    background: var(--bg);
    font-family: var(--sans);
    font-size: 16px;
    scroll-behavior: smooth;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  body {
    position: relative;
    min-height: 100vh;
    margin: 0;
    line-height: 1.65;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    overflow-x: hidden;
  }

  .bg-aura {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(48rem 32rem at 78% -8%, var(--accent-soft), transparent 60%),
      radial-gradient(40rem 30rem at 2% 8%, rgba(29, 111, 139, 0.07), transparent 55%);
  }

  img {
    max-width: 100%;
    display: block;
  }

  main {
    width: min(100% - 2rem, var(--max-width));
    flex: 1;
    margin: 0 auto;
    padding: 0 0 5.5rem;
  }

  ::selection {
    background: var(--burnt);
    color: #fff;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.45rem 0.65rem;
    color: #ffffff;
    background: var(--charcoal);
    border-radius: 6px;
    transform: translateY(-150%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid transparent;
    backdrop-filter: saturate(160%) blur(16px);
    transition: border-color 200ms ease, background 200ms ease;
  }

  .site-header-inner {
    width: min(100% - 2rem, var(--max-width));
    min-height: 72px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-name {
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--ink);
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-mark {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-grid;
    place-items: center;
    color: #fff;
    background: linear-gradient(135deg, var(--burnt-bright), var(--burnt-dark));
    border-radius: 9px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: 0 4px 12px rgba(194, 94, 16, 0.3);
  }

  .site-mark.small {
    width: 2rem;
    height: 2rem;
    font-size: 0.72rem;
  }

  .site-name:hover {
    color: var(--burnt);
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.2rem;
    font-size: 0.94rem;
    font-weight: 500;
  }

  .site-nav a {
    position: relative;
    min-height: 2.3rem;
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    text-decoration: none;
    padding: 0.35rem 0.78rem;
    border-radius: 8px;
    transition: color 160ms ease, background 160ms ease;
  }

  .site-nav a::after {
    content: "";
    position: absolute;
    left: 0.78rem;
    right: 0.78rem;
    bottom: 0.28rem;
    height: 2px;
    background: var(--burnt);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--ink);
  }

  .site-nav a:hover::after,
  .site-nav a.active::after {
    transform: scaleX(1);
  }

  .nav-cv {
    color: var(--burnt) !important;
    border: 1px solid var(--accent-line);
    background: var(--accent-soft);
  }

  .nav-cv::after {
    display: none;
  }

  .nav-cv:hover {
    background: var(--burnt) !important;
    color: #fff !important;
  }

  .theme-toggle {
    width: 2.3rem;
    height: 2.3rem;
    margin-left: 0.35rem;
    display: inline-grid;
    place-items: center;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 9px;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .theme-toggle:hover {
    color: var(--burnt);
    border-color: var(--accent-line);
    background: var(--accent-soft);
    transform: translateY(-1px);
  }

  .icon-moon { display: none; }
  :root[data-theme="dark"] .icon-sun { display: none; }
  :root[data-theme="dark"] .icon-moon { display: block; }

  /* Footer */
  footer {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 2.4rem 1rem;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    width: min(100% - 2rem, var(--max-width));
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.4rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .footer-brand strong {
    color: var(--ink);
    font-size: 0.98rem;
  }

  .footer-brand p {
    margin: 0.1rem 0 0;
    font-size: 0.85rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border-radius: 7px;
    transition: color 160ms ease, background 160ms ease;
  }

  .footer-links a:hover {
    color: var(--burnt);
    background: var(--accent-soft);
  }

  .footer-copy {
    margin: 0;
    font-size: 0.82rem;
  }

  /* Typography */
  h1, h2, h3 {
    color: var(--ink);
    margin: 0;
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  h1, h2 {
    font-family: var(--serif);
    font-weight: 600;
  }

  h1 {
    font-size: clamp(2.6rem, 6vw, 4rem);
    font-weight: 600;
  }

  h2 {
    font-size: clamp(1.55rem, 3vw, 1.95rem);
    margin-bottom: 1rem;
  }

  h3 {
    font-family: var(--sans);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  p {
    margin: 0 0 0.9rem;
  }

  a {
    color: var(--blue);
    text-underline-offset: 0.18em;
    text-decoration-thickness: 1px;
    transition: color 160ms ease;
  }

  a:hover {
    color: var(--burnt);
  }

  ul, ol {
    margin: 0.4rem 0 0.8rem 1.2rem;
    padding: 0;
  }

  li {
    margin: 0.32rem 0;
  }

  .plain-list {
    list-style: none;
    margin-left: 0;
  }

  :focus-visible {
    outline: 2px solid var(--burnt);
    outline-offset: 3px;
  }

  /* Reveal animation */
  [data-reveal] {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 620ms cubic-bezier(0.22, 1, 0.36, 1), transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.001ms !important;
      transition-duration: 0.001ms !important;
      scroll-behavior: auto !important;
    }
    [data-reveal] { opacity: 1; transform: none; }
  }

  .page-heading {
    max-width: 860px;
    padding: 3.4rem 0 1.6rem;
    margin-bottom: 0.75rem;
  }

  .page-heading p,
  .lead {
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.6;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--burnt);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.7rem;
  }

  .eyebrow::before {
    content: "";
    width: 1.6rem;
    height: 2px;
    background: var(--burnt);
    border-radius: 2px;
  }

  .section {
    margin-top: 3.6rem;
  }

  .section:first-child {
    margin-top: 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .section-heading > p,
  .section-heading > a {
    color: var(--muted);
    margin: 0;
    max-width: 520px;
    font-size: 0.96rem;
  }

  .section-heading > a {
    color: var(--burnt);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .section-heading > a:hover {
    text-decoration: underline;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .button {
    min-height: 2.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    color: #fff;
    background: linear-gradient(135deg, var(--burnt-bright), var(--burnt-dark));
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 0.55rem 1.15rem;
    font-weight: 600;
    font-size: 0.96rem;
    text-decoration: none;
    box-shadow: 0 6px 18px rgba(194, 94, 16, 0.25);
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button:hover {
    color: #fff;
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 10px 26px rgba(194, 94, 16, 0.34);
  }

  .button.secondary {
    color: var(--ink);
    background: var(--paper);
    border-color: var(--line-strong);
    box-shadow: var(--shadow-soft);
  }

  .button.secondary:hover {
    color: var(--burnt);
    border-color: var(--accent-line);
    background: var(--paper-2);
  }

  .modern-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.05rem;
  }

  .surface {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .publication-list,
  .news-list {
    display: grid;
    gap: 0;
  }

  .publication-entry {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    padding: 1.3rem 1.1rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  .publication-entry + .publication-entry {
    margin-top: 0.2rem;
  }

  .publication-entry:hover {
    background: var(--paper);
    border-color: var(--line);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .publication-entry h3 {
    font-size: 1.14rem;
    color: var(--ink);
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .publication-entry h3 a {
    color: var(--ink);
    text-decoration: none;
  }

  .publication-entry h3 a:hover {
    color: var(--burnt);
  }

  .pub-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .pub-topline span {
    display: inline-flex;
    align-items: center;
    min-height: 1.6rem;
    color: var(--burnt);
    background: var(--accent-soft);
    border: 1px solid var(--accent-line);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    font-family: var(--mono);
  }

  .publication-entry p {
    margin-bottom: 0.3rem;
  }

  .authors {
    color: var(--charcoal);
    font-size: 0.96rem;
  }

  .venue,
  .meta {
    color: var(--muted);
    font-style: italic;
    font-size: 0.92rem;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.9rem;
    margin-top: 0.7rem;
  }

  .link-row a {
    display: inline-flex;
    align-items: center;
    min-height: 1.95rem;
    color: var(--blue);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 160ms ease, background 160ms ease, border-color 160ms ease;
  }

  .link-row a:hover {
    color: #fff;
    background: var(--burnt);
    border-color: var(--burnt);
  }

  @media (max-width: 820px) {
    main,
    .site-header-inner {
      width: min(100% - 1.2rem, var(--max-width));
    }

    .site-header-inner {
      min-height: 64px;
    }

    .modern-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* Stacked mobile header: brand on its own row, nav centered below */
  @media (max-width: 640px) {
    .site-header-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 0.55rem;
      padding: 0.7rem 0;
      min-height: 0;
    }

    .site-name {
      align-self: flex-start;
    }

    .site-nav {
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.15rem 0.2rem;
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    main,
    .site-header-inner {
      width: min(100% - 1rem, var(--max-width));
    }

    .site-nav {
      gap: 0.1rem;
      font-size: 0.9rem;
