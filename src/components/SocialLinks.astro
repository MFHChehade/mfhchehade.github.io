---
const links = [
  { label: "Google Scholar", url: "https://scholar.google.com/citations?user=cVUnhukAAAAJ&hl=en" },
  { label: "GitHub", url: "https://github.com/MFHChehade" },
  { label: "LinkedIn", url: "https://lb.linkedin.com/in/mfhchehade" },
];
---

<div class="social-links">
  {links.map((link) => {
    const isExternal = link.url.startsWith("http");
    return (
      <a
        href={link.url}
        target={isExternal ? "_blank" : undefined}
        rel={isExternal ? "noopener noreferrer" : undefined}
      >
        {link.label}
      </a>
    );
  })}
</div>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-links a {
    min-height: 2rem;
    display: inline-flex;
    align-items: center;
    color: var(--blue);
    background: var(--wash);
    border-radius: 6px;
    padding: 0.25rem 0.65rem;
    font-size: 0.92rem;
    text-decoration: none;
  }

  .social-links a:hover {
    color: #ffffff;
    background: var(--burnt);
  }
</style>
