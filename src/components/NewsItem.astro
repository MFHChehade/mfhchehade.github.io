---
interface Props {
  date: string;
  content: string;
}

const { date, content } = Astro.props;
---

<article class="news-item">
  <time>{date}</time>
  <div set:html={content} />
</article>

<style>
  .news-item {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
  }

  .news-item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  time {
    color: var(--primary);
    font-weight: 800;
    white-space: nowrap;
  }

  div {
    color: var(--ink);
  }

  a {
    font-weight: 700;
  }

  @media (max-width: 620px) {
    .news-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
