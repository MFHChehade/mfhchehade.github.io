---
interface Props {
  date: string;
  content: string;
}

const { date, content } = Astro.props;
---

<article class="news-item">
  <time>{date}</time>
  <span set:html={content} />
</article>

<style>
  .news-item {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 0.75rem;
  }

  time {
    color: var(--muted);
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .news-item {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
  }
</style>
